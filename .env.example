# Boloroo Chatbot Configuration
# Copy this file to .env and fill in your values

# Server
HOST=127.0.0.1
PORT=8000
DEBUG=true

# CORS origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── LLM: Google Gemini (free tier) ─────────────────────────────────────
# Get a free API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
LLM_TEMPERATURE=0.15
LLM_MAX_TOKENS=400

# ── Vector store: ChromaDB (embedded) ──────────────────────────────────
# Persisted under data/vectors/chroma/ by default. No server needed.
CHROMA_COLLECTION=boloroo_corpus

# ── Embeddings: BGE-M3 (multilingual, runs locally) ────────────────────
# 1024-dim. Strong on Mongolian Cyrillic. ~560MB download on first use.
EMBEDDING_MODEL=BAAI/bge-m3

# ── Reranker: BGE-reranker-v2-m3 (optional, improves answer quality) ──
# Toggle off if RAM is tight; retrieval still works without it.
USE_RERANKER=true
RERANKER_MODEL=BAAI/bge-reranker-v2-m3

# ── RAG retrieval ──────────────────────────────────────────────────────
TOP_K=4
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# ── Safety classifier ──────────────────────────────────────────────────
SAFETY_CONFIDENCE_THRESHOLD=0.5
